    <div class="cta-inner">

      <div class="cta-left">
        <div class="cta-rule"></div>
        <h2 class="cta-headline">Let's make it happen.</h2>
        <p class="cta-body">
          VOICE only works if we build it together. Add your voice. Follow the journey.
        </p>
        <p class="cta-tagline"><em>Help make this real.</em></p>
      </div>

      <div class="cta-boxes">

        <div class="cta-box">
          <div class="cta-box-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 20c4.4 0 8-3.6 8-8s-3.6-8-8-8-8 3.6-8 8 3.6 8 8 8z" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="cta-box-title">Try VOICE</h3>
          <p class="cta-box-desc">Be one of the first to have a real conversation about what matters to you.</p>
          <a href="#/portal/signup" class="cta-box-link">Speak now →</a>
        </div>

        <div class="cta-box">
          <div class="cta-box-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="cta-box-title">Follow the journey</h3>
          <p class="cta-box-desc">See how your voice and everyone else's create real change.</p>
          <a href="#/portal/signup" class="cta-box-link">Stay updated →</a>
        </div>

        <div class="cta-box">
          <div class="cta-box-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="cta-box-title">Help make it real</h3>
          <p class="cta-box-desc">We need developers, designers, donors and believers. If that's you, let's talk.</p>
          <a href="mailto:trevor@thinkmorestupidless.com" class="cta-box-link">Let's talk →</a>
        </div>

      </div>
    </div>
  </div>
</section>

{{/contentFor}}
