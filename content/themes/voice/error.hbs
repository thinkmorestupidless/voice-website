{{!< default}}

{{#contentFor "content"}}
<main class="error-page">
  <div class="container">
    <div class="error-inner">
      <p class="error-code">{{statusCode}}</p>
      <h1 class="error-title">{{#is "404"}}Page not found.{{else}}Something went wrong.{{/is}}</h1>
      <p class="error-message">{{#is "404"}}The page you're looking for doesn't exist.{{else}}{{message}}{{/is}}</p>
      <a href="{{@site.url}}" class="btn-primary">← Back to VOICE</a>
    </div>
  </div>
</main>
{{/contentFor}}
