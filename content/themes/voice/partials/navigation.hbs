<nav class="site-nav">
  <a href="{{@site.url}}" class="nav-brand" aria-label="VOICE. — Home">
    <img src="{{asset "images/logo-tagline.svg"}}" class="nav-logo" alt="VOICE. Politics reimagined." width="280" height="120">
  </a>
  <ul class="nav-links">
    {{#foreach navigation}}
      {{#if @last}}
        <li><a href="{{url}}" class="nav-cta">{{label}}</a></li>
      {{else}}
        <li><a href="{{url}}">{{label}}</a></li>
      {{/if}}
    {{/foreach}}
  </ul>
</nav>
